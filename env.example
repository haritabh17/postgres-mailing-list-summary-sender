# Frontend (Vite). Anything prefixed with VITE_ is bundled into the public
# client JS. NEVER put a service role key or any other secret behind a VITE_
# prefix.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Vercel API layer (api/thread-redirect.ts). Server-only.
SUPABASE_FUNCTIONS_BASE_URL=https://your-project-ref.functions.supabase.co
SUPABASE_EDGE_FUNCTION_KEY=your-supabase-anon-or-edge-function-key

# Supabase Edge Function secrets — set these in the Supabase dashboard
# (Settings → Edge Functions → Secrets), NOT in this file. They are listed
# here only as documentation of what each function expects:
#
#   SUPABASE_URL                (preset by Supabase)
#   SUPABASE_SERVICE_ROLE_KEY   (preset by Supabase, used by all functions)
#   OPENAI_API_KEY              (generate-summary)
#   RESEND_API_KEY              (subscribe, send-confirmation-email,
#                                request-unsubscribe, send-summary-to-user)
#   UNSUBSCRIBE_HMAC_SECRET     (>= 32 chars; signs unsubscribe tokens used by
#                                request-unsubscribe / confirm-unsubscribe /
#                                send-summary-to-user)
#   ALLOWED_SITE_ORIGINS        (optional; comma-separated extra origins the
#                                subscribe / request-unsubscribe functions are
#                                allowed to use when building user-facing URLs)
#
# Database secret (app_secrets table) — required after migration
# 20260515120000_security_hardening.sql. Run once in the SQL editor:
#
#   SELECT set_app_secret(
#     'supabase_service_role_key',
#     '<your-service-role-jwt>',
#     'Cron HTTP bearer for gated edge functions'
#   );
